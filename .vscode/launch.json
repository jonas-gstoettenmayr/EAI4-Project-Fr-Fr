{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug on Pi",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/${config:app.buildDir}/${config:app.name}",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb-multiarch",
      "miDebuggerServerAddress": "${config:pi.host}:${config:pi.port}",
      "preLaunchTask": "deploy",
      "stopAtEntry": true,
      "externalConsole": false,
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
